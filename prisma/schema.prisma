generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 法规表 - 存储法规的基本信息和元数据
model Law {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 法规名称 - 如：中华人民共和国公司法
  title                     String
  /// 制定机关 - 如：全国人大常委会、国务院等
  issuingAuthority          String?
  /// 发文字号 - 如：主席令第66号、国令第748号等
  documentNumber            String?
  /// 序言内容 - 如：修正前的全文、修订说明等
  preamble                  String?
  /// 公布日期 - 法规公布的日期
  promulgationDate          DateTime?
  /// 施行日期 - 法规开始生效的日期
  effectiveDate             DateTime?
  /// 时效性 - 如：现行有效、已废止、已被修订、尚未生效等
  status                    String?     @default("现行有效")
  /// 效力位阶 - 如：法律、行政法规、部门规章、地方性法规、地方政府规章、规范性文件等
  /// 注：经济特区法规和海南自由贸易港法规已整合到"地方性法规" (2026-01-29)
  level                     String      @default("法律")
  /// 法规类别 - 如：食品安全、药品监管、反垄断等
  category                  String      @default("综合监管")
  /// 适用地区 - 如：全国、北京、上海、河北等
  region                    String?
  /// 法规组ID - 用于关联同一法规的不同版本（历史版本）
  /// 基于标题的MD5哈希值生成，同名的法规会有相同的lawGroupId
  /// 例如：公司法的2023版和1993版会有相同的lawGroupId
  lawGroupId                String?
  /// 创建时间 - 记录创建时间戳
  createdAt                 DateTime    @default(now())
  /// 更新时间 - 记录最后修改时间戳
  updatedAt                 DateTime    @updatedAt
  articles                  Article[]
  punishmentBasisViolations Violation[] @relation("PunishmentBasisLaw")
  violationBasisViolations  Violation[] @relation("ViolationBasisLaw")

  @@index([title])
  @@index([category])
  @@index([region])
  @@index([status])
  @@index([lawGroupId])
}

/// 条表 - 存储法规的"条"，是法规的基本层级
model Article {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属法规ID - 外键关联到Law表
  lawId                     Int
  /// 所属章 - 如：第一章 总则、第二章 管理体制等（可选）
  chapter                   String?
  /// 所属节 - 如：第一节 一般规定、第二节 管理机关等（可选）
  section                   String?
  /// 条款号 - 如：第一条、第二条等
  title                     String
  /// 排序序号 - 用于控制条款的显示顺序
  order                     Int         @default(0)
  law                       Law         @relation(fields: [lawId], references: [id], onDelete: Cascade)
  paragraphs                Paragraph[]
  punishmentBasisViolations Violation[] @relation("PunishmentBasisArticle")
  violationBasisViolations  Violation[] @relation("ViolationBasisArticle")

  @@index([lawId])
  @@index([title])
}

/// 款表 - 存储条的"款"，是可选层级
model Paragraph {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属条ID - 外键关联到Article表
  articleId                 Int
  /// 款的序号 - 如：1、2、3等（通常不显示"第一款"，而是自然段编号）
  number                    Int
  /// 款的正文 - 如果没有项，直接存储完整内容；如果有项，可为空
  content                   String?
  /// 排序序号 - 用于控制款的显示顺序
  order                     Int         @default(0)
  items                     Item[]
  article                   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  punishmentBasisViolations Violation[] @relation("PunishmentBasisParagraph")
  violationBasisViolations  Violation[] @relation("ViolationBasisParagraph")

  @@index([articleId])
  @@index([content])
}

/// 项表 - 存储款的"项"，是最小存储单元
model Item {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属款ID - 外键关联到Paragraph表
  paragraphId               Int
  /// 项的序号 - 如：（一）、（二）、（三）等
  number                    String
  /// 项的正文
  content                   String
  /// 排序序号 - 用于控制项的显示顺序
  order                     Int         @default(0)
  paragraph                 Paragraph   @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  punishmentBasisViolations Violation[] @relation("PunishmentBasisItem")
  violationBasisViolations  Violation[] @relation("ViolationBasisItem")

  @@index([paragraphId])
  @@index([content])
}

/// 违法行为表 - 存储违法行为及其法律依据
model Violation {
  /// 主键ID - 自增主键
  id                         Int        @id @default(autoincrement())
  /// 违法行为编码 - 如：A001、B002等（格式：类别字母+3位数字）
  code                       String?    @unique
  /// 类别编码 - A-Z，根据法规的category动态生成
  categoryCode               String?
  /// 违法行为描述 - 详细描述违法行为的内容
  description                String
  /// 违法依据所属法规ID - 外键关联到Law表
  violationBasisLawId        Int?
  /// 违法依据所属条款ID - 外键关联到Article表
  violationBasisArticleId    Int?
  /// 违法依据所属款ID - 外键关联到Paragraph表（可选）
  violationBasisParagraphId  Int?
  /// 违法依据所属项ID - 外键关联到Item表（可选）
  violationBasisItemId       Int?
  /// 处罚依据所属法规ID - 外键关联到Law表
  punishmentBasisLawId       Int?
  /// 处罚依据所属条款ID - 外键关联到Article表
  punishmentBasisArticleId   Int?
  /// 处罚依据所属款ID - 外键关联到Paragraph表（可选）
  punishmentBasisParagraphId Int?
  /// 处罚依据所属项ID - 外键关联到Item表（可选）
  punishmentBasisItemId      Int?
  /// 裁量标准 - 包含从轻、从重、减轻等情形的完整文本
  /// 格式示例：【从轻处罚情形】（一）...【从重处罚情形】（一）...
  sentencingGuidelines       String?
  /// 处罚建议 - 针对该违法行为的具体处罚措施建议
  /// 格式示例：责令限期改正、处以XXX元罚款等
  punishmentSuggestion       String?
  /// 创建时间 - 记录创建时间戳
  createdAt                  DateTime   @default(now())
  /// 更新时间 - 记录最后修改时间戳
  updatedAt                  DateTime   @updatedAt
  punishmentBasisItem        Item?      @relation("PunishmentBasisItem", fields: [punishmentBasisItemId], references: [id])
  punishmentBasisParagraph   Paragraph? @relation("PunishmentBasisParagraph", fields: [punishmentBasisParagraphId], references: [id])
  punishmentBasisArticle     Article?   @relation("PunishmentBasisArticle", fields: [punishmentBasisArticleId], references: [id])
  punishmentBasisLaw         Law?       @relation("PunishmentBasisLaw", fields: [punishmentBasisLawId], references: [id])
  violationBasisItem         Item?      @relation("ViolationBasisItem", fields: [violationBasisItemId], references: [id])
  violationBasisParagraph    Paragraph? @relation("ViolationBasisParagraph", fields: [violationBasisParagraphId], references: [id])
  violationBasisArticle      Article?   @relation("ViolationBasisArticle", fields: [violationBasisArticleId], references: [id])
  violationBasisLaw          Law?       @relation("ViolationBasisLaw", fields: [violationBasisLawId], references: [id])

  @@index([violationBasisLawId])
  @@index([punishmentBasisLawId])
  @@index([categoryCode])
}

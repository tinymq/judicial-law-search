generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 行业分类表 - 司法部标准，71个一级行业
model Industry {
  /// 主键ID - 自增主键
  id               Int               @id @default(autoincrement())
  /// 行业编码 - 如 "30" = 市场监督管理
  code             String            @unique
  /// 行业名称 - 如 "市场监督管理"
  name             String
  /// 父级编码 - null 表示一级行业
  parentCode       String?
  /// 排序序号
  order            Int               @default(0)
  /// 关联法规（旧的一对多，保留兼容）
  laws             Law[]
  /// 关联法规（多对多）
  lawIndustries    LawIndustry[]
  /// 关联执法事项
  enforcementItems EnforcementItem[]

  @@index([parentCode])
}

/// 法规表 - 存储法规的基本信息和元数据
model Law {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 法规名称 - 如：中华人民共和国公司法
  title                     String
  /// 制定机关 - 如：全国人大常委会、国务院等
  issuingAuthority          String?
  /// 发文字号 - 如：主席令第66号、国令第748号等
  documentNumber            String?
  /// 序言内容 - 如：修正前的全文、修订说明等
  preamble                  String?
  /// 公布日期 - 法规公布的日期
  promulgationDate          DateTime?
  /// 施行日期 - 法规开始生效的日期
  effectiveDate             DateTime?
  /// 时效性 - 如：现行有效、已废止、已被修订、尚未生效等
  status                    String?     @default("现行有效")
  /// 效力位阶 - 如：法律、行政法规、部门规章、地方性法规、地方政府规章、规范性文件等
  level                     String      @default("法律")
  /// 法规类别 - 已废弃，由 Industry + LawIndustry 替代
  category                  String?
  /// 适用地区 - 如：全国、江苏、北京等
  region                    String?
  /// 所属行业ID - 关联 Industry 表
  industryId                Int?
  /// 法规组ID - 用于关联同一法规的不同版本（历史版本）
  lawGroupId                String?
  /// 条款显示格式 - 'standard' = 第X条 | 'ordinal' = 一、二、三
  articleFormat             String      @default("standard")
  /// 领域归属范围 - 'universal' 通用基础法 | 'multi_domain' 多领域法 | 'domain_specific' 领域专属法
  scope                    String      @default("domain_specific")
  /// 所修改的法规ID列表 - 逗号分隔，如 "6818,7001"
  modifiesLawIds           String?
  /// 创建时间 - 记录创建时间戳
  createdAt                 DateTime    @default(now())
  /// 更新时间 - 记录最后修改时间戳
  updatedAt                 DateTime    @updatedAt
  articles                  Article[]
  industry                  Industry?   @relation(fields: [industryId], references: [id])
  lawIndustries             LawIndustry[]
  enforcementItems          EnforcementItem[]
  feedbacks                 LawFeedback[]

  @@index([title])
  @@index([region])
  @@index([status])
  @@index([lawGroupId])
  @@index([industryId])
  @@index([modifiesLawIds])
}

/// 执法事项表 - 各省执法事项目录（含行政检查事项扩展字段）
model EnforcementItem {
  /// 主键ID - 自增主键
  id                 Int       @id @default(autoincrement())
  /// 序号
  sequenceNumber     Int
  /// 执法事项名称 - 行政检查格式：检查对象+检查内容+行政检查
  name               String
  /// 执法类别 - 行政许可/行政强制/行政处罚/行政检查 等
  category           String
  /// 执法主体 - 机构名称，如"省市场监督管理局"
  enforcementBody    String?
  /// 承办机构
  handlingDepartment String?
  /// 执法依据原文 - 完整文本，用于展示
  legalBasisText     String?
  /// 备注
  remarks            String?
  /// 省份代码 - 如 "320000" = 江苏
  province           String
  /// 所属行业ID
  industryId         Int?
  /// 关联行业
  industry           Industry? @relation(fields: [industryId], references: [id])
  /// 创建时间
  createdAt          DateTime  @default(now())
  /// 更新时间
  updatedAt          DateTime  @updatedAt

  // === 检查事项扩展字段 ===
  /// 18位唯一编码 - 省(2)+领域(2)+主体层级(4)+序列(10)
  code               String?   @unique
  /// 行使层级 - 省级/市级/县级/乡级
  enforcementLevel   String?
  /// 检查对象 - 如"食品生产企业"
  checkTarget        String?
  /// 检查内容 - 如"生产经营活动"
  checkContent       String?
  /// 检查方式 - 如"现场检查""书面检查""网络监测"
  checkMethod        String?
  /// 执法领域 - 二级分类，如"市场监管""生态环境"
  enforcementDomain  String?
  /// 事项状态 - 生效/暂停
  itemStatus         String?   @default("生效")
  /// 来源法规ID - 关联Law表
  lawId              Int?
  /// 关联法规
  law                Law?      @relation(fields: [lawId], references: [id])
  /// 父事项ID - 用于父子事项层级关系
  parentId           Int?
  /// 父事项
  parent             EnforcementItem?  @relation("ParentChild", fields: [parentId], references: [id])
  /// 子事项列表
  children           EnforcementItem[] @relation("ParentChild")

  @@index([category])
  @@index([province])
  @@index([industryId])
  @@index([name])
  @@index([code])
  @@index([enforcementLevel])
  @@index([enforcementDomain])
  @@index([itemStatus])
  @@index([lawId])
  @@index([parentId])
}

/// 条表 - 存储法规的"条"，是法规的基本层级
model Article {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属法规ID - 外键关联到Law表
  lawId                     Int
  /// 所属章 - 如：第一章 总则、第二章 管理体制等（可选）
  chapter                   String?
  /// 所属节 - 如：第一节 一般规定、第二节 管理机关等（可选）
  section                   String?
  /// 条款号 - 如：第一条、第二条等
  title                     String
  /// 排序序号 - 用于控制条款的显示顺序
  order                     Int         @default(0)
  law                       Law         @relation(fields: [lawId], references: [id], onDelete: Cascade)
  paragraphs                Paragraph[]

  @@index([lawId])
  @@index([title])
}

/// 款表 - 存储条的"款"，是可选层级
model Paragraph {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属条ID - 外键关联到Article表
  articleId                 Int
  /// 款的序号 - 如：1、2、3等（通常不显示"第一款"，而是自然段编号）
  number                    Int
  /// 款的正文 - 如果没有项，直接存储完整内容；如果有项，可为空
  content                   String?
  /// 排序序号 - 用于控制款的显示顺序
  order                     Int         @default(0)
  items                     Item[]
  article                   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([content])
}

/// 项表 - 存储款的"项"，是最小存储单元
model Item {
  /// 主键ID - 自增主键
  id                        Int         @id @default(autoincrement())
  /// 所属款ID - 外键关联到Paragraph表
  paragraphId               Int
  /// 项的序号 - 如：（一）、（二）、（三）等
  number                    String
  /// 项的正文
  content                   String
  /// 排序序号 - 用于控制项的显示顺序
  order                     Int         @default(0)
  paragraph                 Paragraph   @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@index([paragraphId])
  @@index([content])
}

/// 法规反馈表 - 用户对法规内容的问题反馈
model LawFeedback {
  /// 主键ID - 自增主键
  id          Int      @id @default(autoincrement())
  /// 关联法规ID - 外键关联到Law表
  lawId       Int
  /// 法规标题快照 - 冗余存储，法规删除后仍可读
  lawTitle    String
  /// 问题类型 - 数据错误/内容缺失/格式问题/条款错误/其他
  issueType   String   @default("数据错误")
  /// 问题描述 - 用户填写的详细描述
  description String
  /// 联系方式 - 可选，用于后续跟进
  contact     String?
  /// 处理状态 - 待处理/处理中/已解决/已忽略
  status      String   @default("待处理")
  /// 管理员备注 - 处理结果说明
  adminNote   String?
  /// 创建时间
  createdAt   DateTime @default(now())
  /// 更新时间
  updatedAt   DateTime @updatedAt
  /// 关联法规
  law         Law      @relation(fields: [lawId], references: [id], onDelete: Cascade)

  @@index([lawId])
  @@index([status])
  @@index([createdAt])
}

/// 法规-行业 多对多关联表
model LawIndustry {
  /// 主键ID
  id         Int      @id @default(autoincrement())
  /// 法规ID
  lawId      Int
  /// 行业ID
  industryId Int
  /// 是否为主分类
  isPrimary  Boolean  @default(false)
  /// 关联法规
  law        Law      @relation(fields: [lawId], references: [id], onDelete: Cascade)
  /// 关联行业
  industry   Industry @relation(fields: [industryId], references: [id])

  @@unique([lawId, industryId])
  @@index([lawId])
  @@index([industryId])
}
